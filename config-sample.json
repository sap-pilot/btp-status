{
  "variables": {
    "svc.username": "monitor@example.com",
    "svc.password": "s3cr3t"
  },
  "landscapes": [
    {
      "name": "production",
      "diagram": "flowchart LR\n    User[End User] --> my-service\n    my-service --> my-service-db[(Database)]"
    },
    {
      "name": "staging",
      "diagram": "flowchart LR\n    User[End User] --> my-service-staging"
    }
  ],
  "services": [
    {
      "group": "MyApp",
      "name": "my-service",
      "enabled": true,
      "landscapes": ["production"],
      "interval": 900,
      "homepage": "https://my-service.example.com",
      "endpoints": [
        {
          "name": "Health Check",
          "url": "https://my-service.example.com/health",
          "method": "GET",
          "conditions": [
            "[STATUS] == 200",
            "[RESPONSE_TIME] < 3000"
          ]
        },
        {
          "mode": "browser-ias-login",
          "name": "Login Check",
          "url": "https://my-service.example.com/login",
          "username": "{{svc.username}}",
          "password": "{{svc.password}}",
          "waitForSelector": "#app-shell-title",
          "timeout": 30000
        }
      ]
    },
    {
      "group": "MyApp",
      "name": "my-service-staging",
      "enabled": true,
      "landscapes": ["staging"],
      "interval": 1800,
      "endpoints": [
        {
          "name": "Health Check",
          "url": "/dummy",
          "method": "GET",
          "conditions": [
            "[STATUS] == 200"
          ]
        }
      ]
    }
  ]
}

{
  "services": [
    {
      "group": "WorkZone",
      "name": "dcore-sandbox",
      "enabled": true,
      "interval": 300,
      "homepage": "https://{subdomain}.launchpad.cfapps.us10.ondemand.com/site/{site}",
      "endpoints": [
        {
          "name": "Workzone Redirect",
          "url": "https://{subdomain}.launchpad.cfapps.us10.ondemand.com/site/{site}",
          "method": "GET",
          "headers": {},
          "body": null,
          "conditions": [
            "[STATUS] == 200",
            "[RESPONSE_TIME] < 30000"
          ]
        },
        {
          "mode": "browser-ias-login",
          "name": "Workzone Login",
          "url": "https://{subdomain}.launchpad.cfapps.us10.ondemand.com/site/{site}?sap_idp={idp}",
          "username": "nonprod.monitor@sap-test.de",
          "password": "my-password",
          "waitForUrl": "https://{subdomain}.launchpad.cfapps.us10.hana.ondemand.com/site/{site}sap_idp={idp}#Shell-home",
          "timeout": 30000
        }
      ]
    },
    {
      "group": "WorkZone",
      "name": "hrp-prod",
      "enabled": true,
      "interval": 60,
      "homepage": "https://example.hana.ondemand.com",
      "endpoints": [
        {
          "name": "API Health",
          "url": "https://example.hana.ondemand.com/api/health",
          "method": "GET",
          "headers": {
            "Accept": "application/json"
          },
          "body": null,
          "conditions": [
            "[STATUS] == 200",
            "[RESPONSE_TIME] < 2000",
            "[BODY].status == \"healthy\""
          ]
        },
        {
          "name": "Login Page",
          "url": "https://example.hana.ondemand.com/login",
          "method": "GET",
          "headers": {},
          "body": null,
          "conditions": [
            "[STATUS] == 200",
            "[BODY] == pat(*login*)"
          ]
        }
      ]
    },
    {
      "group": "Integration",
      "name": "erp-webhook",
      "enabled": true,
      "interval": 0,
      "endpoints": [
        {
          "name": "Webhook Ping",
          "url": "https://example.com/webhook/ping",
          "method": "POST",
          "headers": {
            "Content-Type": "application/json",
            "X-API-Key": "your-api-key"
          },
          "body": "{\"ping\":true}",
          "conditions": [
            "[STATUS] == 200",
            "[RESPONSE_TIME] < 5000",
            "[HEADER.content-type] == pat(*application/json*)",
            "len([BODY].services) > 0"
          ]
        }
      ]
    }
  ]
}
